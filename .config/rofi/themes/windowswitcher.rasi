/* windowswitcher.rasi — window switcher */
@import "~/.config/rofi/themes/colors.rasi"

* {
    background-color:   transparent;
    text-color:         @fg0;
}

window {
    background-color:   @bg0;
    border:             2px solid;
    border-color:       @acc;
    border-radius:      16px;
    width:              600px;
    padding:            0px;
}

mainbox {
    background-color:   transparent;
    children:           [ inputbar, listview ];
    padding:            12px;
    spacing:            10px;
}

inputbar {
    background-color:   @bg1;
    border-radius:      10px;
    padding:            10px 14px;
    children:           [ prompt, entry ];
    spacing:            8px;
}

prompt {
    background-color:   transparent;
    text-color:         @acc;
    font:               "JetBrainsMono Nerd Font 13";
}

entry {
    background-color:   transparent;
    text-color:         @fg0;
    placeholder:        "Search windows...";
    placeholder-color:  @fg1;
}

listview {
    background-color:   transparent;
    columns:            1;
    lines:              6;
    spacing:            4px;
    scrollbar:          false;
    fixed-height:       false;
}

element {
    background-color:   @bg1;
    border-radius:      8px;
    padding:            8px 12px;
    spacing:            10px;
    orientation:        horizontal;
}

element normal.normal {
    background-color:   @bg1;
    text-color:         @fg0;
}

element selected.normal {
    background-color:   @acc-bg;
    text-color:         @acc-fg2;
}

element-icon {
    background-color:   transparent;
    size:               24px;
}

element-text {
    background-color:   transparent;
    text-color:         inherit;
    vertical-align:     0.5;
}
